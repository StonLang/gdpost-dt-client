# gdpost-dt-client environment variables example
# Copy this file to .env and modify the values

# Server API configuration
API_BASE_URL=http://localhost:8000
API_CONFIGS_ENDPOINT=/api/v1/api-configs/login
API_UPLOAD_ENDPOINT=/api/v1/capture/upload

# Authentication
API_KEY=your-secret-api-key-here
CLIENT_ID=client-windows-01

# Polling interval (seconds), default 5 minutes
POLL_INTERVAL=300

# Logging configuration
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# WinDivert：默认全部 TCP（不限制 IP/端口）；可按需改为例如 tcp and outbound
DIVERT_FILTER=tcp
DIVERT_PRIORITY=0

# Proxy configuration
PROXY_HOST=127.0.0.1
PROXY_PORT=0

# HTTP connection timeout
CONNECT_TIMEOUT=10
READ_TIMEOUT=30
